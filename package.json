    "@radix-ui/react-slot": "1.2.4",
    "@react-pdf/renderer": "4.5.0",
    "@strum/colors": "0.1.8",
    "babel-plugin-react-compiler": "1.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "contentlayer2": "0.5.8",
    "eslint": "10.2.0",
    "eslint-config-next": "16.2.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-unicorn": "64.0.0",
    "next": "16.2.3",
    "next-contentlayer2": "0.5.8",
    "next-themes": "0.4.6",
    "npm-run-all2": "8.0.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-pdf-html": "2.1.5",
    "tailwind-merge": "3.5.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "20.9.0",
    "@tailwindcss/postcss": "4.2.2",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "bun-types": "1.3.12",
    "knip": "6.4.1",
    "postcss": "8.5.13",
    "prettier": "3.8.3",
    "prettier-plugin-sort-json": "4.2.0",
    "prettier-plugin-tailwindcss": "0.7.2",
    "syncpack": "14.3.0",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2"
  },
  "homepage": "https://github.com/colinhemphill/nextjs-resume",
  "keywords": [
    "generator",
    "nextjs",
    "pdf",
    "resume",
    "tailwind"
  ],
  "license": "MIT",
  "name": "nextjs-resume",
  "overrides": {
    "@react-pdf/image": "3.0.4"
  },
  "scripts": {
    "build": "contentlayer2 build && next build",
    "build:content": "contentlayer2 build",
    "dev": "run-p dev:*",
    "dev:contentlayer": "contentlayer2 dev",
    "dev:next": "next dev --turbopack",
    "format": "prettier --write 'src/**/*.{json,js,ts,tsx}' && syncpack format",
    "knip": "knip-bun --fix --allow-remove-files",
    "lint": "eslint --fix . && syncpack format && syncpack lint",
    "start": "next start",
    "sync": "syncpack fix-mismatches",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:update": "bun test --update-snapshots",
    "test:watch": "bun test --watch",
    "types": "tsc -p tsconfig.json --noEmit",
    "update": "syncpack update",
    "yeet": "bunx rimraf bun.lockb && bunx rimraf **/{dist,node_modules,.turbo,.next,.vercel,.netlify,__snapshots__}/ --glob && bunx rimraf **/tsconfig.tsbuildinfo --glob"
  },
  "type": "module",
  "version": "8.1.5"
}